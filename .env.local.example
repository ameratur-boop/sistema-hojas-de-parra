# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (SECRETO, solo server). Lo usa el bot de Telegram para escribir sin sesión.
SUPABASE_SERVICE_ROLE_KEY=

# Bot de Telegram (config después con @BotFather)
TELEGRAM_BOT_TOKEN=
# Secreto para validar el webhook de Telegram (inventá uno largo)
TELEGRAM_WEBHOOK_SECRET=
# IDs de Telegram autorizados a usar el bot, separados por coma (ej: 123456789,987654321)
TELEGRAM_ALLOWED_IDS=

# Claude API (para interpretar mensajes del bot)
ANTHROPIC_API_KEY=
